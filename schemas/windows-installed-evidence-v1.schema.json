{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CongBao/stock-desk/schemas/windows-installed-evidence-v1.schema.json",
  "title": "Stock Desk installed Windows and WebView2 evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact",
    "scenario",
    "identity",
    "execution",
    "system",
    "account",
    "webview",
    "processes",
    "security",
    "install",
    "window",
    "v1_canary",
    "diagnostic_summary",
    "uninstall"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact": { "const": "windows-installed-evidence" },
    "scenario": {
      "enum": ["webview-preinstalled", "webview-absent", "webview-install-failure"]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_sha",
        "source_tree",
        "main_proof_sha256",
        "candidate_sha256",
        "webview_installer_sha256"
      ],
      "properties": {
        "source_sha": { "$ref": "#/$defs/gitObject" },
        "source_tree": { "$ref": "#/$defs/gitObject" },
        "main_proof_sha256": { "$ref": "#/$defs/sha256" },
        "candidate_sha256": { "$ref": "#/$defs/sha256" },
        "webview_installer_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow",
        "run_id",
        "run_attempt",
        "job_id",
        "job_name",
        "scenario_attempt",
        "attempt_id"
      ],
      "properties": {
        "workflow": { "type": "string", "minLength": 1, "maxLength": 128 },
        "run_id": { "type": "integer", "minimum": 1 },
        "run_attempt": { "type": "integer", "minimum": 1 },
        "job_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]{1,128}$" },
        "job_name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "scenario_attempt": { "type": "integer", "minimum": 1 },
        "attempt_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,127}$" }
      }
    },
    "system": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family",
        "display_version",
        "build_number",
        "update_build_revision",
        "architecture",
        "image_sha256"
      ],
      "properties": {
        "family": { "enum": ["windows-10", "windows-11"] },
        "display_version": { "type": "string", "pattern": "^[0-9]{2}H[12]$" },
        "build_number": { "type": "integer", "minimum": 1 },
        "update_build_revision": { "type": "integer", "minimum": 0 },
        "architecture": { "const": "x86_64" },
        "image_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_type",
        "is_admin",
        "username_contains_non_ascii",
        "profile_path_contains_space"
      ],
      "properties": {
        "account_type": { "const": "standard" },
        "is_admin": { "type": "boolean" },
        "username_contains_non_ascii": { "type": "boolean" },
        "profile_path_contains_space": { "type": "boolean" }
      }
    },
    "webview": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "installation", "after"],
      "properties": {
        "before": { "$ref": "#/$defs/webviewRuntime" },
        "installation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["attempted", "exit_code", "installer_sha256"],
          "properties": {
            "attempted": { "type": "boolean" },
            "exit_code": { "type": ["integer", "null"] },
            "installer_sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "after": { "$ref": "#/$defs/webviewRuntime" }
      }
    },
    "processes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installer", "desktop_host", "sidecar", "uninstaller"],
      "properties": {
        "installer": { "$ref": "#/$defs/processObservation" },
        "desktop_host": { "$ref": "#/$defs/processObservation" },
        "sidecar": { "$ref": "#/$defs/processObservation" },
        "uninstaller": { "$ref": "#/$defs/processObservation" }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uac_prompt_count", "elevation_requested"],
      "properties": {
        "uac_prompt_count": { "type": "integer", "minimum": 0 },
        "elevation_requested": { "type": "boolean" }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exit_code",
        "application_files_present",
        "shortcut_present",
        "launchable"
      ],
      "properties": {
        "exit_code": { "type": "integer" },
        "application_files_present": { "type": "boolean" },
        "shortcut_present": { "type": "boolean" },
        "launchable": { "type": "boolean" }
      }
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed",
        "main_window_count",
        "title",
        "external_browser_window_count",
        "rendered_content_sha256"
      ],
      "properties": {
        "observed": { "type": "boolean" },
        "main_window_count": { "type": "integer", "minimum": 0 },
        "title": { "type": ["string", "null"], "maxLength": 128 },
        "external_browser_window_count": { "type": "integer", "minimum": 0 },
        "rendered_content_sha256": {
          "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        }
      }
    },
    "v1_canary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["before", "after"],
      "properties": {
        "before": { "$ref": "#/$defs/canarySnapshot" },
        "after": { "$ref": "#/$defs/canarySnapshot" }
      }
    },
    "diagnostic_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["archive_sha256", "entry_count", "redaction_scan", "records"],
      "properties": {
        "archive_sha256": { "$ref": "#/$defs/sha256" },
        "entry_count": { "type": "integer", "minimum": 1, "maximum": 64 },
        "redaction_scan": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "secret_match_count",
            "username_match_count",
            "absolute_path_match_count"
          ],
          "properties": {
            "secret_match_count": { "type": "integer", "minimum": 0 },
            "username_match_count": { "type": "integer", "minimum": 0 },
            "absolute_path_match_count": { "type": "integer", "minimum": 0 }
          }
        },
        "records": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "sha256", "size_bytes"],
            "properties": {
              "kind": {
                "enum": [
                  "account-token",
                  "diagnostic-summary",
                  "failure-capture",
                  "install-log",
                  "process-token",
                  "uac-observation",
                  "uninstall-log",
                  "v1-canary",
                  "webview-inventory",
                  "window-capture"
                ]
              },
              "sha256": { "$ref": "#/$defs/sha256" },
              "size_bytes": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "uninstall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempted", "exit_code", "application_files_removed", "shortcuts_removed"],
      "properties": {
        "attempted": { "type": "boolean" },
        "exit_code": { "type": ["integer", "null"] },
        "application_files_removed": { "type": ["boolean", "null"] },
        "shortcuts_removed": { "type": ["boolean", "null"] }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitObject": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "signer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "subject", "certificate_sha256"],
      "properties": {
        "status": { "const": "Valid" },
        "subject": { "const": "CN=Microsoft Corporation" },
        "certificate_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "webviewRuntime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "product_guid", "version", "channel", "signer"],
      "properties": {
        "state": { "enum": ["present", "absent"] },
        "product_guid": { "enum": ["{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}", null] },
        "version": { "type": ["string", "null"], "pattern": "^[0-9]+(?:\\.[0-9]+){3}$", "maxLength": 64 },
        "channel": { "enum": ["evergreen", null] },
        "signer": { "anyOf": [{ "$ref": "#/$defs/signer" }, { "type": "null" }] }
      }
    },
    "processObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started", "elevated"],
      "properties": {
        "started": { "type": "boolean" },
        "elevated": { "type": ["boolean", "null"] }
      }
    },
    "canarySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_count", "content_sha256"],
      "properties": {
        "entry_count": { "type": "integer", "minimum": 1 },
        "content_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
