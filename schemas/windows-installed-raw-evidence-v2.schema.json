{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CongBao/stock-desk/schemas/windows-installed-raw-evidence-v2.schema.json",
  "title": "Stock Desk raw installed-Windows desktop observation package v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "artifact", "case_id", "scenario", "identity", "execution", "capture", "records"],
  "properties": {
    "schema_version": { "const": 2 },
    "artifact": { "const": "windows-installed-raw-evidence" },
    "case_id": { "type": "string", "pattern": "^(win10-22h2|win11)-dpi-(100|125|150|175|200)(-webview-offline)?$" },
    "scenario": { "enum": ["installed-first-use", "webview-install-failure"] },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_sha", "source_tree", "main_proof_sha256", "candidate_sha256", "webview_installer_sha256"],
      "properties": {
        "source_sha": { "$ref": "#/$defs/gitObject" },
        "source_tree": { "$ref": "#/$defs/gitObject" },
        "main_proof_sha256": { "$ref": "#/$defs/sha256" },
        "candidate_sha256": { "$ref": "#/$defs/sha256" },
        "webview_installer_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository", "workflow", "workflow_ref", "workflow_sha", "workflow_path",
        "workflow_sha256", "run_id", "run_attempt", "job_id", "job_name",
        "matrix_case_id", "matrix_guest_profile", "matrix_scenario", "matrix_dpi_percent",
        "matrix_controller_label", "scenario_attempt", "attempt_id"
      ],
      "properties": {
        "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
        "workflow": { "type": "string", "minLength": 1, "maxLength": 128 },
        "workflow_ref": { "type": "string", "minLength": 1, "maxLength": 512 },
        "workflow_sha": { "$ref": "#/$defs/gitObject" },
        "workflow_path": { "const": ".github/workflows/windows-installed.yml" },
        "workflow_sha256": { "$ref": "#/$defs/sha256" },
        "run_id": { "type": "integer", "minimum": 1 },
        "run_attempt": { "const": 1 },
        "job_id": { "type": "string", "pattern": "^[A-Za-z0-9_.-]{1,128}$" },
        "job_name": { "type": "string", "minLength": 1, "maxLength": 128 },
        "matrix_case_id": { "type": "string", "pattern": "^(win10-22h2|win11)-dpi-(100|125|150|175|200)(-webview-offline)?$" },
        "matrix_guest_profile": { "enum": ["win10-22h2", "win11"] },
        "matrix_scenario": { "enum": ["installed-first-use", "webview-install-failure"] },
        "matrix_dpi_percent": { "enum": [100, 125, 150, 175, 200] },
        "matrix_controller_label": { "type": "string", "pattern": "^stock-desk-vm-controller-(win10-22h2|win11)$" },
        "scenario_attempt": { "const": 1 },
        "attempt_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{7,127}$" }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "started_at_utc", "completed_at_utc", "guest_profile", "controller_label",
        "dpi_percent", "guest_harness_sha256", "uia_driver_sha256",
        "controller_request_sha256", "snapshot_policy_sha256", "clean_snapshot_sha256",
        "image_sha256", "webview_product_guid", "minimum_webview_version",
        "failure_injection", "data_path", "redaction_version"
      ],
      "properties": {
        "started_at_utc": { "$ref": "#/$defs/utcTimestamp" },
        "completed_at_utc": { "$ref": "#/$defs/utcTimestamp" },
        "guest_profile": { "enum": ["win10-22h2", "win11"] },
        "controller_label": { "type": "string", "pattern": "^stock-desk-vm-controller-(win10-22h2|win11)$" },
        "dpi_percent": { "enum": [100, 125, 150, 175, 200] },
        "guest_harness_sha256": { "$ref": "#/$defs/sha256" },
        "uia_driver_sha256": { "$ref": "#/$defs/sha256" },
        "controller_request_sha256": { "$ref": "#/$defs/sha256" },
        "snapshot_policy_sha256": { "$ref": "#/$defs/sha256" },
        "clean_snapshot_sha256": { "$ref": "#/$defs/sha256" },
        "image_sha256": { "$ref": "#/$defs/sha256" },
        "webview_product_guid": { "const": "{F3017226-FE2A-4295-8BDF-00C3A9A7E4C5}" },
        "minimum_webview_version": { "const": "120.0.2210.91" },
        "failure_injection": { "$ref": "#/$defs/failureInjection" },
        "data_path": { "enum": ["primary", "primary-blocked-fallback"] },
        "redaction_version": { "const": "stock-desk-public-redaction-v2" }
      }
    },
    "records": {
      "type": "array",
      "minItems": 3,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256", "size_bytes", "media_type"],
        "properties": {
          "kind": { "enum": ["observation-stream", "install-log", "uia-action-trace", "uia-tree", "focus-region-contact-sheet", "window-capture-standard", "window-capture-narrow", "failure-diagnostic"] },
          "path": { "type": "string", "pattern": "^raw/[a-z0-9][a-z0-9._-]{0,95}$" },
          "sha256": { "$ref": "#/$defs/sha256" },
          "size_bytes": { "type": "integer", "minimum": 1, "maximum": 8388608 },
          "media_type": { "enum": ["application/json", "application/x-ndjson", "text/plain; charset=utf-8", "image/png"] }
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitObject": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "utcTimestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "failureInjection": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["identity", "sha256"],
          "properties": {
            "identity": { "const": "stock-desk-webview2-offline-install-failure-v1" },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      ]
    }
  }
}
