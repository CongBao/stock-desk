{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CongBao/stock-desk/schemas/deployment-latency-sample-v1.schema.json",
  "title": "Stock Desk deployment latency raw sample v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "run_attempt",
    "run_url",
    "source_sha",
    "source_tree",
    "workflow",
    "ref",
    "category",
    "queued_at",
    "started_at",
    "completed_at",
    "queue_seconds",
    "wall_seconds",
    "cache_status",
    "outcome",
    "environment_baseline",
    "invalidated",
    "invalidation_reason"
  ],
  "properties": {
    "schema_version": { "const": "stock-desk-deployment-latency-sample-v1" },
    "run_id": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "run_attempt": { "type": "integer", "minimum": 1 },
    "run_url": {
      "type": "string",
      "pattern": "^https://github\\.com/CongBao/stock-desk/actions/runs/[1-9][0-9]*/attempts/[1-9][0-9]*$"
    },
    "source_sha": { "$ref": "#/$defs/git_id" },
    "source_tree": { "$ref": "#/$defs/git_id" },
    "workflow": { "type": "string", "minLength": 1, "maxLength": 256 },
    "ref": { "type": "string", "pattern": "^refs/", "maxLength": 512 },
    "category": {
      "enum": [
        "typical-pr",
        "high-risk-pr",
        "main",
        "candidate",
        "signpath-queue",
        "proved-tag-to-release"
      ]
    },
    "queued_at": { "$ref": "#/$defs/utc_timestamp" },
    "started_at": { "$ref": "#/$defs/utc_timestamp" },
    "completed_at": { "$ref": "#/$defs/utc_timestamp" },
    "queue_seconds": { "type": "number", "minimum": 0 },
    "wall_seconds": { "type": "number", "minimum": 0 },
    "cache_status": {
      "enum": ["hit", "miss", "partial", "disabled", "unknown"]
    },
    "outcome": {
      "enum": ["success", "failure", "cancelled", "timed_out", "skipped"]
    },
    "environment_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "architecture", "runner_image", "toolchain"],
      "properties": {
        "os": { "type": "string", "minLength": 1, "maxLength": 256 },
        "architecture": { "type": "string", "minLength": 1, "maxLength": 64 },
        "runner_image": { "type": "string", "minLength": 1, "maxLength": 256 },
        "toolchain": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "invalidated": { "type": "boolean" },
    "invalidation_reason": { "type": ["string", "null"], "minLength": 1, "maxLength": 1024 }
  },
  "allOf": [
    {
      "if": { "properties": { "invalidated": { "const": true } } },
      "then": { "properties": { "invalidation_reason": { "type": "string" } } },
      "else": { "properties": { "invalidation_reason": { "type": "null" } } }
    }
  ],
  "$defs": {
    "git_id": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    }
  }
}
