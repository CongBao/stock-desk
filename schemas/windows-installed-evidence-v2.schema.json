{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CongBao/stock-desk/schemas/windows-installed-evidence-v2.schema.json",
  "title": "Stock Desk derived Windows desktop acceptance evidence v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact", "case_id", "scenario", "identity", "execution",
    "system", "hardware", "account", "display", "webview", "network", "security",
    "install", "journey", "uia", "filesystem", "window", "v1_canary", "uninstall",
    "raw_package_sha256"
  ],
  "properties": {
    "schema_version": { "const": 2 },
    "artifact": { "const": "windows-installed-evidence" },
    "case_id": { "$ref": "#/$defs/caseId" },
    "scenario": { "enum": ["installed-first-use", "webview-install-failure"] },
    "identity": { "$ref": "#/$defs/identity" },
    "execution": { "$ref": "#/$defs/execution" },
    "system": { "$ref": "#/$defs/system" },
    "hardware": { "$ref": "#/$defs/hardware" },
    "account": { "$ref": "#/$defs/account" },
    "display": { "oneOf": [{ "$ref": "#/$defs/display" }, { "type": "null" }] },
    "webview": { "$ref": "#/$defs/webview" },
    "network": { "$ref": "#/$defs/network" },
    "security": { "$ref": "#/$defs/security" },
    "install": { "$ref": "#/$defs/install" },
    "journey": { "oneOf": [{ "$ref": "#/$defs/journey" }, { "type": "null" }] },
    "uia": { "oneOf": [{ "$ref": "#/$defs/uia" }, { "type": "null" }] },
    "filesystem": { "$ref": "#/$defs/filesystem" },
    "window": { "$ref": "#/$defs/window" },
    "v1_canary": { "$ref": "#/$defs/v1Canary" },
    "uninstall": { "$ref": "#/$defs/uninstall" },
    "raw_package_sha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "gitObject": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "timestamp": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "caseId": { "type": "string", "pattern": "^(win10-22h2|win11)-dpi-(100|125|150|175|200)(-webview-offline)?$" },
    "identity": {
      "type": "object", "additionalProperties": false,
      "required": ["source_sha", "source_tree", "main_proof_sha256", "candidate_sha256", "webview_installer_sha256"],
      "properties": {
        "source_sha": { "$ref": "#/$defs/gitObject" }, "source_tree": { "$ref": "#/$defs/gitObject" },
        "main_proof_sha256": { "$ref": "#/$defs/sha256" }, "candidate_sha256": { "$ref": "#/$defs/sha256" },
        "webview_installer_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "execution": {
      "type": "object", "additionalProperties": false,
      "required": ["repository", "workflow", "workflow_ref", "workflow_sha", "workflow_path", "workflow_sha256", "run_id", "run_attempt", "job_id", "job_name", "matrix_case_id", "matrix_guest_profile", "matrix_scenario", "matrix_dpi_percent", "matrix_controller_label", "scenario_attempt", "attempt_id"],
      "properties": {
        "repository": { "type": "string" }, "workflow": { "type": "string" }, "workflow_ref": { "type": "string" },
        "workflow_sha": { "$ref": "#/$defs/gitObject" }, "workflow_path": { "const": ".github/workflows/windows-installed.yml" },
        "workflow_sha256": { "$ref": "#/$defs/sha256" }, "run_id": { "type": "integer", "minimum": 1 },
        "run_attempt": { "const": 1 }, "job_id": { "type": "string" }, "job_name": { "type": "string" },
        "matrix_case_id": { "$ref": "#/$defs/caseId" }, "matrix_guest_profile": { "enum": ["win10-22h2", "win11"] },
        "matrix_scenario": { "enum": ["installed-first-use", "webview-install-failure"] },
        "matrix_dpi_percent": { "enum": [100, 125, 150, 175, 200] }, "matrix_controller_label": { "type": "string" },
        "scenario_attempt": { "const": 1 }, "attempt_id": { "type": "string" }
      }
    },
    "system": {
      "type": "object", "additionalProperties": false,
      "required": ["family", "display_version", "build_number", "update_build_revision", "architecture", "image_sha256"],
      "properties": {
        "family": { "enum": ["windows-10", "windows-11"] }, "display_version": { "type": "string" },
        "build_number": { "type": "integer" }, "update_build_revision": { "type": "integer" },
        "architecture": { "const": "x86_64" }, "image_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "hardware": {
      "type": "object", "additionalProperties": false,
      "required": ["architecture", "logical_processor_count", "memory_bytes", "free_disk_bytes", "graphics_adapter_sha256", "screen_physical_pixels", "timezone", "locale"],
      "properties": {
        "architecture": { "const": "x86_64" }, "logical_processor_count": { "type": "integer" },
        "memory_bytes": { "type": "integer" }, "free_disk_bytes": { "type": "integer" },
        "graphics_adapter_sha256": { "$ref": "#/$defs/sha256" }, "timezone": { "type": "string" }, "locale": { "type": "string" },
        "screen_physical_pixels": {
          "type": "object", "additionalProperties": false, "required": ["width", "height"],
          "properties": { "width": { "type": "integer" }, "height": { "type": "integer" } }
        }
      }
    },
    "account": {
      "type": "object", "additionalProperties": false,
      "required": ["account_type", "is_admin", "administrator_group_member", "linked_token_present", "token_elevation_type", "integrity_level", "integrity_rid", "username_contains_non_ascii", "profile_path_contains_space"],
      "properties": {
        "account_type": { "const": "standard" }, "is_admin": { "const": false },
        "administrator_group_member": { "const": false }, "linked_token_present": { "const": false },
        "token_elevation_type": { "const": "default" }, "integrity_level": { "const": "medium" },
        "integrity_rid": { "const": 8192 }, "username_contains_non_ascii": { "const": true },
        "profile_path_contains_space": { "const": true }
      }
    },
    "display": {
      "type": "object", "additionalProperties": false,
      "required": ["requested_scale_percent", "get_dpi_for_window", "get_dpi_for_system", "get_dpi_for_monitor_x", "get_dpi_for_monitor_y", "window_dpi_awareness_context", "logical_to_physical_roundtrip_max_error_px", "dpi_virtualized", "logical_window_sizes"],
      "properties": {
        "requested_scale_percent": { "enum": [100, 125, 150, 175, 200] }, "get_dpi_for_window": { "type": "integer" },
        "get_dpi_for_system": { "type": "integer" }, "get_dpi_for_monitor_x": { "type": "integer" }, "get_dpi_for_monitor_y": { "type": "integer" },
        "window_dpi_awareness_context": { "const": "per-monitor-v2" }, "logical_to_physical_roundtrip_max_error_px": { "type": "integer" },
        "dpi_virtualized": { "const": false }, "logical_window_sizes": { "type": "array", "items": { "$ref": "#/$defs/displaySize" } }
      }
    },
    "displaySize": {
      "type": "object", "additionalProperties": false,
      "required": ["width", "height", "physical_width", "physical_height", "within_work_area", "clipped_component_count", "overlap_count"],
      "properties": {
        "width": { "type": "integer" }, "height": { "type": "integer" }, "physical_width": { "type": "integer" },
        "physical_height": { "type": "integer" }, "within_work_area": { "const": true }, "clipped_component_count": { "const": 0 }, "overlap_count": { "const": 0 }
      }
    },
    "signer": {
      "type": "object", "additionalProperties": false, "required": ["status", "subject", "certificate_sha256"],
      "properties": { "status": { "const": "Valid" }, "subject": { "type": "string" }, "certificate_sha256": { "$ref": "#/$defs/sha256" } }
    },
    "webviewState": {
      "type": "object", "additionalProperties": false,
      "required": ["state", "product_guid", "version", "channel", "signer", "scope"],
      "properties": {
        "state": { "enum": ["present", "absent"] }, "product_guid": { "type": ["string", "null"] },
        "version": { "type": ["string", "null"] }, "channel": { "type": ["string", "null"] },
        "signer": { "oneOf": [{ "$ref": "#/$defs/signer" }, { "type": "null" }] }, "scope": { "type": ["string", "null"] }
      }
    },
    "webviewInstallation": {
      "type": "object", "additionalProperties": false, "required": ["attempted", "exit_code", "installer_sha256", "fault_injection"],
      "properties": {
        "attempted": { "type": "boolean" },
        "exit_code": { "type": ["integer", "null"] },
        "installer_sha256": { "$ref": "#/$defs/sha256" },
        "fault_injection": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": { "identity": { "type": "string" }, "sha256": { "$ref": "#/$defs/sha256" } }
        }
      }
    },
    "webview": {
      "type": "object", "additionalProperties": false, "required": ["before", "installation", "after"],
      "properties": { "before": { "$ref": "#/$defs/webviewState" }, "installation": { "$ref": "#/$defs/webviewInstallation" }, "after": { "$ref": "#/$defs/webviewState" } }
    },
    "networkRecord": {
      "type": "object", "additionalProperties": false,
      "required": ["provider", "operation", "host", "started_at_utc", "completed_at_utc", "tls_system_validation", "outcome"],
      "properties": {
        "provider": { "type": "string" }, "operation": { "type": "string" }, "host": { "type": "string" },
        "started_at_utc": { "$ref": "#/$defs/timestamp" }, "completed_at_utc": { "$ref": "#/$defs/timestamp" },
        "tls_system_validation": { "const": true }, "outcome": { "enum": ["success", "blocked-by-policy", "offline-failure"] },
        "payload_sha256": { "$ref": "#/$defs/sha256" }, "cutoff_utc": { "$ref": "#/$defs/timestamp" }, "row_count": { "type": "integer" }
      }
    },
    "network": {
      "type": "object", "additionalProperties": false,
      "required": ["capture_api", "profile", "policy_sha256", "unexpected_host_count", "telemetry_request_count", "proxy_used", "records"],
      "properties": {
        "capture_api": { "const": "DNS Client + WFP/ETW" }, "profile": { "type": "string" },
        "policy_sha256": { "$ref": "#/$defs/sha256" }, "unexpected_host_count": { "const": 0 },
        "telemetry_request_count": { "const": 0 }, "proxy_used": { "const": false },
        "records": { "type": "array", "items": { "$ref": "#/$defs/networkRecord" } }
      }
    },
    "process": {
      "type": "object", "additionalProperties": false, "required": ["role", "started", "elevated", "integrity_level", "integrity_rid"],
      "properties": { "role": { "type": "string" }, "started": { "type": "boolean" }, "elevated": { "type": ["boolean", "null"] }, "integrity_level": { "type": ["string", "null"] }, "integrity_rid": { "type": ["integer", "null"] } }
    },
    "uac": {
      "type": "object", "additionalProperties": false, "required": ["uac_prompt_count", "elevation_requested"],
      "properties": { "uac_prompt_count": { "const": 0 }, "elevation_requested": { "const": false } }
    },
    "security": {
      "type": "object", "additionalProperties": false, "required": ["uac", "processes"],
      "properties": {
        "uac": { "$ref": "#/$defs/uac" },
        "processes": {
          "type": "object", "additionalProperties": false,
          "properties": { "installer": { "$ref": "#/$defs/process" }, "desktop_host": { "$ref": "#/$defs/process" }, "sidecar": { "$ref": "#/$defs/process" }, "uninstaller": { "$ref": "#/$defs/process" } },
          "required": ["installer"]
        }
      }
    },
    "install": {
      "type": "object", "additionalProperties": false, "required": ["exit_code", "application_files_present", "shortcut_present", "launchable"],
      "properties": { "exit_code": { "type": "integer" }, "application_files_present": { "type": "boolean" }, "shortcut_present": { "type": "boolean" }, "launchable": { "type": "boolean" } }
    },
    "instrument": {
      "type": "object", "additionalProperties": false, "required": ["symbol", "name", "exchange", "instrument_kind", "period"],
      "properties": { "symbol": { "const": "000001.SS" }, "name": { "const": "上证指数" }, "exchange": { "const": "SH" }, "instrument_kind": { "const": "index" }, "period": { "const": "1d" } }
    },
    "journeySource": {
      "type": "object", "additionalProperties": false, "required": ["provider", "provider_label", "cutoff_utc", "row_count", "catalog_sha256", "bars_sha256"],
      "properties": { "provider": { "enum": ["akshare", "baostock"] }, "provider_label": { "type": "string" }, "cutoff_utc": { "$ref": "#/$defs/timestamp" }, "row_count": { "type": "integer", "minimum": 1 }, "catalog_sha256": { "$ref": "#/$defs/sha256" }, "bars_sha256": { "$ref": "#/$defs/sha256" } }
    },
    "fallback": {
      "type": "object", "additionalProperties": false, "required": ["primary_blocked", "fallback_used", "whole_segment", "primary_provider", "fallback_provider"],
      "properties": { "primary_blocked": { "type": "boolean" }, "fallback_used": { "type": "boolean" }, "whole_segment": { "const": true }, "primary_provider": { "const": "akshare" }, "fallback_provider": { "type": ["string", "null"] } }
    },
    "journey": {
      "type": "object", "additionalProperties": false,
      "required": ["elapsed_seconds", "primary_click_count", "onboarding_steps", "instrument", "real_data", "demo", "kline_rendered", "source", "fallback"],
      "properties": {
        "elapsed_seconds": { "type": "number", "exclusiveMinimum": 0, "maximum": 180 }, "primary_click_count": { "type": "integer", "maximum": 5 },
        "onboarding_steps": { "const": ["welcome", "data_preparation", "instrument_selection", "synchronization"] },
        "instrument": { "$ref": "#/$defs/instrument" }, "real_data": { "const": true }, "demo": { "const": false },
        "kline_rendered": { "const": true }, "source": { "$ref": "#/$defs/journeySource" }, "fallback": { "$ref": "#/$defs/fallback" }
      }
    },
    "component": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "parent_id", "x", "y", "width", "height", "is_offscreen", "is_enabled", "keyboard_focusable", "hit_test_id"],
      "properties": { "id": { "type": "string" }, "parent_id": { "type": ["string", "null"] }, "x": { "type": "integer" }, "y": { "type": "integer" }, "width": { "type": "integer" }, "height": { "type": "integer" }, "is_offscreen": { "const": false }, "is_enabled": { "const": true }, "keyboard_focusable": { "type": "boolean" }, "hit_test_id": { "type": "string" } }
    },
    "layoutCheck": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_size", "window_bounds", "component_bounds", "clipped_component_count", "overlap_count", "tab_sequence", "focused_element_id", "focus_visible", "focus_evidence", "escape_result"],
      "properties": {
        "logical_size": { "$ref": "#/$defs/size" }, "window_bounds": { "$ref": "#/$defs/rectangle" },
        "component_bounds": { "type": "array", "items": { "$ref": "#/$defs/component" } },
        "clipped_component_count": { "const": 0 }, "overlap_count": { "const": 0 },
        "tab_sequence": { "type": "array", "items": { "type": "string" } }, "focused_element_id": { "type": "string" },
        "focus_visible": { "const": true }, "focus_evidence": { "$ref": "#/$defs/tabFocusEvidence" }, "escape_result": { "enum": ["closed-safe", "confirmation-preserved"] }
      }
    },
    "size": { "type": "object", "additionalProperties": false, "required": ["width", "height"], "properties": { "width": { "type": "integer" }, "height": { "type": "integer" } } },
    "rectangle": { "type": "object", "additionalProperties": false, "required": ["x", "y", "width", "height"], "properties": { "x": { "type": "integer" }, "y": { "type": "integer" }, "width": { "type": "integer" }, "height": { "type": "integer" } } },
    "uiaGroup": { "type": "object", "additionalProperties": false, "required": ["id", "checks"], "properties": { "id": { "type": "string" }, "checks": { "type": "array", "items": { "$ref": "#/$defs/layoutCheck" } } } },
    "tabFocusEvidence": { "type": "object", "additionalProperties": false, "required": ["target_id", "target_name", "initial_focus_id", "tab_sequence", "tab_input_count", "focus_observation_method", "target_has_keyboard_focus", "unfocused_region_id", "focused_region_id", "focus_region_changed"], "properties": { "target_id": { "type": "string" }, "target_name": { "type": "string" }, "initial_focus_id": { "type": "string" }, "tab_sequence": { "type": "array", "minItems": 1, "maxItems": 128, "items": { "type": "string" } }, "tab_input_count": { "type": "integer", "minimum": 1, "maximum": 128 }, "focus_observation_method": { "const": "uia-focused-element-after-real-tab" }, "target_has_keyboard_focus": { "const": true }, "unfocused_region_id": { "type": "string" }, "focused_region_id": { "type": "string" }, "focus_region_changed": { "const": true } } },
    "onboardingTabFocusEvidence": { "type": "object", "additionalProperties": false, "required": ["target_id", "target_name", "initial_focus_id", "tab_sequence", "tab_input_count", "focus_observation_method", "target_has_keyboard_focus", "unfocused_region_id", "focused_region_id", "focus_region_changed", "activated"], "properties": { "target_id": { "type": "string" }, "target_name": { "type": "string" }, "initial_focus_id": { "type": "string" }, "tab_sequence": { "type": "array", "minItems": 1, "maxItems": 128, "items": { "type": "string" } }, "tab_input_count": { "type": "integer", "minimum": 1, "maximum": 128 }, "focus_observation_method": { "const": "uia-focused-element-after-real-tab" }, "target_has_keyboard_focus": { "const": true }, "unfocused_region_id": { "type": "string" }, "focused_region_id": { "type": "string" }, "focus_region_changed": { "const": true }, "activated": { "const": true } } },
    "focusRegionCapture": { "type": "object", "additionalProperties": false, "required": ["id", "x", "y", "width", "height"], "properties": { "id": { "type": "string" }, "x": { "const": 0 }, "y": { "type": "integer", "minimum": 0 }, "width": { "type": "integer", "minimum": 2, "maximum": 2048 }, "height": { "type": "integer", "minimum": 2, "maximum": 32768 } } },
    "focusRegions": { "type": "object", "additionalProperties": false, "required": ["schema", "media_kind", "width", "height", "captures"], "properties": { "schema": { "const": "stock-desk-focus-region-contact-sheet-v1" }, "media_kind": { "const": "focus-region-contact-sheet" }, "width": { "type": "integer", "minimum": 2, "maximum": 2048 }, "height": { "type": "integer", "minimum": 4, "maximum": 32768 }, "captures": { "type": "array", "items": { "$ref": "#/$defs/focusRegionCapture" } } } },
    "keyboard": { "type": "object", "additionalProperties": false, "required": ["pure_keyboard_journey", "focus_visible", "tab_order_valid", "safe_escape", "focus_observation_count", "onboarding_tab_paths", "auxiliary_tab_paths"], "properties": { "pure_keyboard_journey": { "const": true }, "focus_visible": { "const": true }, "tab_order_valid": { "const": true }, "safe_escape": { "const": true }, "focus_observation_count": { "type": "integer", "minimum": 30 }, "onboarding_tab_paths": { "type": "array", "minItems": 4, "maxItems": 4, "items": { "$ref": "#/$defs/onboardingTabFocusEvidence" } }, "auxiliary_tab_paths": { "type": "array", "items": { "$ref": "#/$defs/onboardingTabFocusEvidence" } } } },
    "sidebar": { "type": "object", "additionalProperties": false, "required": ["logical_size", "collapsed_before", "toggle_control_type", "toggle_semantic_name", "expanded_after", "expanded_reflow", "chart_x_shift", "sidebar_chart_overlap_pixels"], "properties": { "logical_size": { "$ref": "#/$defs/size" }, "collapsed_before": { "const": true }, "toggle_control_type": { "const": "button" }, "toggle_semantic_name": { "type": "string" }, "expanded_after": { "const": true }, "expanded_reflow": { "const": true }, "chart_x_shift": { "type": "integer", "minimum": 1 }, "sidebar_chart_overlap_pixels": { "const": 0 } } },
    "uia": {
      "type": "object", "additionalProperties": false, "required": ["schema", "api", "driver_sha256", "routes", "dialogs", "keyboard", "focus_regions", "narrow_sidebar"],
      "properties": { "schema": { "const": "stock-desk-windows-uia-matrix-v1" }, "api": { "const": "Windows UI Automation 3 + Win32" }, "driver_sha256": { "$ref": "#/$defs/sha256" }, "routes": { "type": "array", "items": { "$ref": "#/$defs/uiaGroup" } }, "dialogs": { "type": "array", "items": { "$ref": "#/$defs/uiaGroup" } }, "keyboard": { "$ref": "#/$defs/keyboard" }, "focus_regions": { "$ref": "#/$defs/focusRegions" }, "narrow_sidebar": { "$ref": "#/$defs/sidebar" } }
    },
    "filesystem": { "type": "object", "additionalProperties": false, "required": ["install_root_read_only", "install_root_runtime_write_count", "mutable_root_identity", "unexpected_mutable_root_write_count", "legacy_v1_open_count", "legacy_v1_write_count"], "properties": { "install_root_read_only": { "const": true }, "install_root_runtime_write_count": { "const": 0 }, "mutable_root_identity": { "const": "localappdata-stock-desk-v1.1" }, "unexpected_mutable_root_write_count": { "const": 0 }, "legacy_v1_open_count": { "const": 0 }, "legacy_v1_write_count": { "const": 0 } } },
    "browserIdentity": { "type": "object", "additionalProperties": false, "required": ["process_name", "process_id", "window_handle"], "properties": { "process_name": { "type": "string" }, "process_id": { "type": "integer" }, "window_handle": { "type": "integer" } } },
    "browserSample": { "type": "object", "additionalProperties": false, "required": ["captured_at_utc", "phase", "windows"], "properties": { "captured_at_utc": { "$ref": "#/$defs/timestamp" }, "phase": { "enum": ["baseline", "installer", "app-readiness", "stable", "final"] }, "windows": { "type": "array", "items": { "$ref": "#/$defs/browserIdentity" } } } },
    "browserEvent": { "type": "object", "additionalProperties": false, "required": ["sequence", "captured_at_utc", "event", "process_name", "process_id", "window_handle"], "properties": { "sequence": { "type": "integer" }, "captured_at_utc": { "$ref": "#/$defs/timestamp" }, "event": { "enum": ["create", "show", "hide", "destroy"] }, "process_name": { "type": "string" }, "process_id": { "type": "integer" }, "window_handle": { "type": "integer" } } },
    "browserObserver": { "type": "object", "additionalProperties": false, "required": ["schema", "api", "hook_started_at_utc", "baseline_captured_at_utc", "baseline_event_sequence", "final_captured_at_utc", "final_event_sequence", "hook_stopped_at_utc", "subscribed_events", "lifecycle_event_count", "lifecycle_events_sha256"], "properties": { "schema": { "const": "stock-desk-browser-window-observer-v1" }, "api": { "const": "Win32 EnumWindows + SetWinEventHook" }, "hook_started_at_utc": { "$ref": "#/$defs/timestamp" }, "baseline_captured_at_utc": { "$ref": "#/$defs/timestamp" }, "baseline_event_sequence": { "type": "integer" }, "final_captured_at_utc": { "$ref": "#/$defs/timestamp" }, "final_event_sequence": { "type": "integer" }, "hook_stopped_at_utc": { "$ref": "#/$defs/timestamp" }, "subscribed_events": { "const": ["create", "show", "hide", "destroy"] }, "lifecycle_event_count": { "type": "integer" }, "lifecycle_events_sha256": { "$ref": "#/$defs/sha256" } } },
