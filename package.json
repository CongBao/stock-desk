{
  "name": "stock-desk-workspace",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm --dir web build",
    "desktop:build": "tauri build --config src-tauri/tauri.conf.json",
    "desktop:dev": "tauri dev --config src-tauri/tauri.conf.json",
    "desktop:smoke:macos": "uv run --frozen python scripts/macos_tauri_smoke.py",
    "e2e": "playwright test",
    "format:check": "pnpm --dir web format:check",
    "lint": "pnpm --dir web lint",
    "test": "pnpm --dir web test:coverage",
    "typecheck": "pnpm --dir web typecheck"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": ">=1.55.0 <2"
  }
}
