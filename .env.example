# Copy this file to .env for local use. Never commit your .env file.

# Generate a Fernet key locally without embedding a key in source control:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STOCK_DESK_MASTER_KEY=

# Optional application defaults:
# STOCK_DESK_APP_NAME=stock-desk
# STOCK_DESK_DATA_DIR=data
# STOCK_DESK_DATABASE_URL=sqlite:///data/stock-desk.db

# Optional Compose runtime identity overrides. Both values must be nonzero.
# When omitted, Compose preserves an existing non-root ./data owner or uses 10001.
# STOCK_DESK_UID=1000
# STOCK_DESK_GID=1000

# Optional per-checkout image name when multiple Stock Desk builds share one host.
# STOCK_DESK_IMAGE=stock-desk-runtime:local
