# Copy this file to .env for local use. Never commit your .env file.

# Generate a Fernet key locally without embedding a key in source control:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STOCK_DESK_MASTER_KEY=

